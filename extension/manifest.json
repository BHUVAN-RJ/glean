{
  "manifest_version": 3,
  "name": "CSCI 576 AI TA",
  "version": "1.1",
  "description": "AI Teaching Assistant overlay for CSCI 576 lecture videos",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:8080/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:8080/*",
        "http://localhost:8000/player/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "CSCI 576 AI TA"
  }
}
